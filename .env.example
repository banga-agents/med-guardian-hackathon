# ==========================================
# MedGuardian Environment Configuration
# ==========================================

# ------------------------------------------
# Blockchain Configuration
# ------------------------------------------
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
PRIVATE_KEY=your_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key
CRE_RECEIVER_ADDRESS=0x...

# ------------------------------------------
# CRE Configuration
# ------------------------------------------
CRE_API_KEY=your_cre_api_key
CRE_WORKFLOW_DON=workflow_don_identifier
CRE_PRIVATE_SUMMARY_KEY=your_confidential_summary_key
CRE_MUTATION_API_KEY=your_cre_mutation_service_key

# ------------------------------------------
# External API Keys (for secrets.yaml)
# ------------------------------------------
HEALTH_SERVICE_KEY_ALL=your_health_service_api_key
STORAGE_API_KEY_ALL=your_storage_api_key
OPENAI_KEY_ALL=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
AES_KEY_ALL=your_32_byte_hex_encoded_aes_key

# ------------------------------------------
# IPFS/Storage Configuration
# ------------------------------------------
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_project_secret
IPFS_GATEWAY=https://ipfs.io/ipfs/

# ------------------------------------------
# Frontend Configuration
# ------------------------------------------
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_HEALTH_ACCESS_CONTRACT=0x...
NEXT_PUBLIC_REPORT_REGISTRY_CONTRACT=0x...
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ------------------------------------------
# Professional network / marketplace (backend)
# ------------------------------------------
ENABLE_PRO_NETWORK=true
ENABLE_MARKETPLACE_TASKS=true
ENABLE_PAYOUTS=true
