# ==========================================
# MedGuardian Backend Configuration
# ==========================================

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Optional comma-separated allowlist for additional UI origins
# Example: FRONTEND_URLS=http://127.0.0.1:3000,http://100.121.184.92:3000
FRONTEND_URLS=
# In development, allow private/Tailscale origins on port 3000 even if not in explicit allowlist
ALLOW_DEV_ORIGINS=true

# ==========================================
# LLM Provider API Keys
# At least one is required
# ==========================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Local LLM (Ollama)
LOCAL_LLM_URL=http://localhost:11434

# Default provider (gemini, openai, anthropic, local)
DEFAULT_LLM_PROVIDER=gemini

# Provider fallback order
LLM_FALLBACK_ORDER=gemini,openai,anthropic,local

# Keep chat/report flows operational during provider outages by returning deterministic safe responses.
# Set to false only when you want hard failures for provider unavailability.
ENABLE_DETERMINISTIC_LLM_FALLBACK=true

# Agent runtime mode (legacy | akasha)
AGENT_MODE=akasha

# Optional explicit path to med-akasha-blueprint
MED_AKASHA_BLUEPRINT_DIR=../med-akasha-blueprint

# Investigation thread persistence (relative to backend root or absolute path)
INVESTIGATION_STORE_PATH=.runtime/investigation-threads.json

# Timescale/Postgres persistence for MedGuardian memory + audit
# Example: postgres://postgres:postgres@localhost:5432/medguardian
TIMESCALE_DATABASE_URL=
# Required when TIMESCALE_DATABASE_URL is set. Use 32-byte base64, 64-char hex, or strong passphrase.
MEMORY_ENCRYPTION_KEY=
TIMESCALE_SSL=false
# Optional automation: anchor selected audit events automatically
MEDGUARDIAN_AUTO_ANCHOR_EVENTS=false

# Doctor simulator (auto review + consent + plan relay for demo loop)
DOCTOR_SIMULATION_ENABLED=true
DOCTOR_SIMULATION_DELAY_MS=3500

# Professional network / marketplace (new collaborative mode)
ENABLE_PRO_NETWORK=true
ENABLE_MARKETPLACE_TASKS=true
ENABLE_PAYOUTS=true

# Model selection
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_REPORT=gpt-4o
ANTHROPIC_MODEL_CHAT=claude-3-5-haiku-latest
ANTHROPIC_MODEL_REPORT=claude-3-5-sonnet-latest
GEMINI_MODEL_CHAT=gemini-2.5-flash
GEMINI_MODEL_REPORT=gemini-2.5-pro
LOCAL_MODEL_CHAT=llama3.2
LOCAL_MODEL_REPORT=llama3.2

# Live medical evidence retrieval (PubMed eUtils)
ENABLE_LIVE_RESEARCH=true
PUBMED_API_KEY=
RESEARCH_TIMEOUT_MS=4500

# ==========================================
# Blockchain (Optional for simulation)
# ==========================================
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
HEALTH_ACCESS_CONTROL_ADDRESS=0x...
CRE_REQUEST_CONTRACT_ADDRESS=0x...
# Optional direct receiver override for backend writes.
# Leave unset if your CRE workflow writes to a ReceiverTemplate consumer via the Chainlink forwarder.
CRE_RECEIVER_ADDRESS=0x...
# Backward-compat alias:
HEALTH_ACCESS_CONTRACT=0x...
PRIVATE_KEY=your_wallet_private_key
ETH_PRICE_USD=3000
ALLOW_DIRECT_GRANT=false

# ==========================================
# CRE Configuration (Optional)
# ==========================================
CRE_API_KEY=your_cre_api_key
# Service key required by /api/cre/private/summary for Confidential HTTP fetches
CRE_PRIVATE_SUMMARY_KEY=your_confidential_summary_key
# Optional dedicated service key for signer-backed /api/cre/request and /api/cre/dispatch.
# If unset, those routes fall back to CRE_PRIVATE_SUMMARY_KEY.
CRE_MUTATION_API_KEY=your_cre_mutation_service_key
